    {"type": "rectangle","id":"bg_l298n1","x":80,"y":450,"width":360,"height":180,
     "roundness":{"type":3},"backgroundColor":"#ffd8a8","fillStyle":"solid",
     "strokeColor":"#e8590c","strokeWidth":2,
     "boundElements":[{"id":"t_l298n1","type":"text"}]},
    {"type":"text","id":"t_l298n1","x":90,"y":460,"width":340,"height":25,
     "text":"L298N #1 — 前轮驱动 (FR + FL)","fontSize":18,"fontFamily":1,
     "strokeColor":"#1e1e1e","textAlign":"center","verticalAlign":"middle",
     "containerId":"bg_l298n1","originalText":"L298N #1 — 前轮驱动 (FL + FR)","autoResize":true},
    {"type":"text","id":"l298n1_pins","x":100,"y":510,"width":320,"height":100,
     "text":"IN1=17  IN2=18  ENA=12(PWM)  →  FR 右前轮\nIN3=22  IN4=23  ENB=13(PWM)  →  FL 左前轮\n\n⚠ 外接电源 6-12V (VMS 和 GND)",
     "fontSize":16,"fontFamily":1,"strokeColor":"#495057","textAlign":"left",
     "verticalAlign":"top",
     "originalText":"IN1=17  IN2=18  ENA=12(PWM)  →  FR 右前轮\nIN3=22  IN4=23  ENB=13(PWM)  →  FL 左前轮\n\n⚠ 外接电源 6-12V (VMS 和 GND)","autoResize":true},

    {"type":"rectangle","id":"bg_l298n2","x":480,"y":450,"width":360,"height":180,
     "roundness":{"type":3},"backgroundColor":"#ffd8a8","fillStyle":"solid",
     "strokeColor":"#e8590c","strokeWidth":2,
     "boundElements":[{"id":"t_l298n2","type":"text"}]},
    {"type":"text","id":"t_l298n2","x":490,"y":460,"width":340,"height":25,
     "text":"L298N #2 — 后轮驱动 (RR + RL)","fontSize":18,"fontFamily":1,
     "strokeColor":"#1e1e1e","textAlign":"center","verticalAlign":"middle",
     "containerId":"bg_l298n2","originalText":"L298N #2 — 后轮驱动 (RL + RR)","autoResize":true},
    {"type":"text","id":"l298n2_pins","x":500,"y":510,"width":320,"height":100,
     "text":"IN1=24  IN2=25  ENA=19(PWM)  →  RR 右后轮\nIN3=5   IN4=6   ENB=26(PWM)  →  RL 左后轮\n\n⚠ 外接电源 6-12V (VMS 和 GND)",
     "fontSize":16,"fontFamily":1,"strokeColor":"#495057","textAlign":"left",
     "verticalAlign":"top",
     "originalText":"IN1=24  IN2=25  ENA=19(PWM)  →  RR 右后轮\nIN3=5   IN4=6   ENB=26(PWM)  →  RL 左后轮\n\n⚠ 外接电源 6-12V (VMS 和 GND)","autoResize":true},

    {"type":"rectangle","id":"bg_ultrasonic","x":880,"y":450,"width":360,"height":180,
     "roundness":{"type":3},"backgroundColor":"#b2f2bb","fillStyle":"solid",
     "strokeColor":"#2f9e44","strokeWidth":2,
     "boundElements":[{"id":"t_ultrasonic","type":"text"}]},
    {"type":"text","id":"t_ultrasonic","x":890,"y":460,"width":340,"height":25,
     "text":"HY-SRF05 超声波模块","fontSize":18,"fontFamily":1,
     "strokeColor":"#1e1e1e","textAlign":"center","verticalAlign":"middle",
     "containerId":"bg_ultrasonic","originalText":"HY-SRF05 超声波模块","autoResize":true},
    {"type":"text","id":"ultrasonic_pins","x":900,"y":510,"width":320,"height":100,
     "text":"① Vcc=5V  ② Trig=27(GPIO.OUT)\n③ Echo=16(GPIO.IN)  ⚠ 要分压\n④ OUT(报警用，本系统未接)\n⑤ GND\n\n量程 2cm~4.5m · 角度 15°\n工作电流 15mA · 频率 40Hz",
     "fontSize":16,"fontFamily":1,"strokeColor":"#495057","textAlign":"left",
     "verticalAlign":"top",
     "originalText":"① Vcc=5V  ② Trig=27(GPIO.OUT)\n③ Echo=16(GPIO.IN)  ⚠ 要分压\n④ OUT(报警用，本系统未接)\n⑤ GND\n\n量程 2cm~4.5m · 角度 15°\n工作电流 15mA · 频率 40Hz","autoResize":true},

    {"type":"rectangle","id":"bg_servo","x":1280,"y":450,"width":340,"height":180,
     "roundness":{"type":3},"backgroundColor":"#d0bfff","fillStyle":"solid",
     "strokeColor":"#6741d9","strokeWidth":2,
     "boundElements":[{"id":"t_servo","type":"text"}]},
    {"type":"text","id":"t_servo","x":1290,"y":460,"width":320,"height":25,
     "text":"SG90 云台舵机 ×2","fontSize":18,"fontFamily":1,
     "strokeColor":"#1e1e1e","textAlign":"center","verticalAlign":"middle",
     "containerId":"bg_servo","originalText":"SG90 云台舵机 ×2","autoResize":true},
    {"type":"text","id":"servo_pins","x":1295,"y":510,"width":310,"height":100,
     "text":"PAN(水平)  = GPIO 20 (pigpio PWM)\nTILT(俯仰) = GPIO 21 (pigpio PWM)\n\n舵机可从树莓派 5V 取电\n(两个 SG90 共约 500mA)",
     "fontSize":16,"fontFamily":1,"strokeColor":"#495057","textAlign":"left",
     "verticalAlign":"top",
     "originalText":"PAN(水平)  = GPIO 20 (pigpio PWM)\nTILT(俯仰) = GPIO 21 (pigpio PWM)\n\n舵机可从树莓派 5V 取电\n(两个 SG90 共约 500mA)","autoResize":true},

    {"type":"rectangle","id":"bg_cameras","x":1660,"y":450,"width":360,"height":180,
